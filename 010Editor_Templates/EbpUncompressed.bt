typedef uint BLOCKCAPTION <read=BLOCKCAPTIONRead>;
string BLOCKCAPTIONRead(BLOCKCAPTION b )
{
    string str;
    // block index
    int i = b & 0x07ff; //0000 0111 1111 1111
    // 24 Cube Combinations Rotations
    int r = (b & 0xf800) >> 11;
    // domain - not investigated yet
    //int d = (b & 0xff0000) >> 16;
    // children reference
    int c = (b & 0x3E000000) >> 25;
    // some relation with blockid over 2048
    //byte s = (b & 0x80000000) >> 31;
    byte s24 = (b >> 24) & 1;
    byte s30 = (b >> 30) & 1;

    if (s24>0)
    {
        i = i + 2048;
    }

    SPrintf( str, "id_%i r%i c%i (%i %i)", i,r,c,s24,s30);
    return str;
}

