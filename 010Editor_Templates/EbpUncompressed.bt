typedef uint COLORCAPTION <read=COLORCAPTIONRead>;

string COLORCAPTIONRead(COLORCAPTION c )
{
    string str;
    int c1 = c & 0x1F; c = c >> 5;
    int c2 = c & 0x1F; c = c >> 5;
    int c3 = c & 0x1F; c = c >> 5;
    int c4 = c & 0x1F; c = c >> 5;
    int c5 = c & 0x1F; c = c >> 5;
    int c6 = c & 0x1F;

    SPrintf( str, "%i %i %i %i %i %i", c1,c2,c3,c4,c5,c6);
    return str;
}





