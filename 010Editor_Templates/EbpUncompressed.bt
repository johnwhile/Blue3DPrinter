// Chunk method for instances values, chunk size = 8 (like byte size ??? of course !!)

typedef struct{
    int count;
    
    if (count > FileSize() -  FTell())
        return -1;

    if(count>0)
        byte array[count] <format=binary>;

} CHUNK8;



byte GetChunkSolution(CHUNK8 &chunks, int i)
{
    if (chunks.count>0)
    {
        local int ic = i / 8;
        local byte m_chunk = chunks.array[ic];
        local int ii = i % 8;
        return m_chunk & (1 << ii);
    }
    return 0;
}


typedef struct(int length){

    SetBackColor(cDkGreen);
    CHUNK8 chunks;
    SetBackColor(cLtGreen); 
    
    for( i = 0; i < length; i++ )
    {
        if (GetChunkSolution(chunks,i))
        {
            ushort data;
        }
    } 

} USHORT_TABLE <optimize=false>;


